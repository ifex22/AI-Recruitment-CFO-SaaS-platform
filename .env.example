# ── Supabase (required) ───────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_KEY=<your-service-role-key>

# ── Frontend (Vite) — must be prefixed with VITE_ ────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── API Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# Session signing secret (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-256-bit-secret

# ── Demo mode (set to "false" in production to disable demo@nexus.ai login) ──
DEMO_MODE=true

# ── Password reset ────────────────────────────────────────────────────────────
# URL where users land after clicking the reset link in their email
PASSWORD_RESET_URL=https://your-domain.com/reset-password

# ── CORS (comma-separated allowed origins) ───────────────────────────────────
ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
